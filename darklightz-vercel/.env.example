# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI).
# Use the "Transaction" pooler connection string on Vercel (port 6543) so serverless
# functions don't exhaust Supabase's direct connection limit.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres

# Passcode required to open /admin and call admin API routes. Generate any long
# random string, e.g. `openssl rand -base64 24`.
ADMIN_DASHBOARD_KEY=

# Set to your production frontend URL once deployed (e.g. https://darklightz.vercel.app).
# Leave unset locally to allow all origins.
ALLOWED_ORIGIN=

NODE_ENV=development

# ── Client Portal (Phase 3) ───────────────────────────────────────────────
# Supabase project URL and anon key (exposed to the frontend via Vite).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-only — used to verify client JWTs).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend API key for transactional email notifications.
# Sign up at resend.com — free tier is sufficient for most use cases.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives admin notifications (update requests, new messages, etc.).
ADMIN_NOTIFICATION_EMAIL=admin@darklightz.studio

# "From" address for outbound emails. Must be a verified domain in Resend.
FROM_EMAIL=Darklightz Studio <noreply@darklightz.studio>
